# ==========================================
# Modern WordPress Theme .gitignore
# (Tailwind CSS + Vite Setup)
# ==========================================

# 1. Dependencies
node_modules/

# 2. Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 3. OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 4. Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 5. Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 6. WordPress Specific
wp-config.php
wp-config-sample.php

# ==========================================
# NOTE: Built Assets (Vite)
# ==========================================
# By default, we DO NOT ignore the `/assets/` directory 
# because WordPress themes usually need the compiled CSS/JS 
# to be tracked and shipped (e.g., for CodeCanyon or clients).
# If you run builds on your server instead, uncomment the line below:
# /assets/
